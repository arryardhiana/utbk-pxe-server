# dnsmasq configuration template for UTBK PXE Server
# This file is auto-generated by the web UI when you save DHCP configuration.
# Do NOT edit this file manually unless you know what you are doing.
# Copy to dnsmasq.conf and fill in values, or use the web UI to configure.

# TFTP server IP (auto-updated by UI on every Save)
dhcp-option=66,YOUR_SERVER_IP

# Boot file for UEFI PXE (do not change)
dhcp-option=67,bootx64.efi

# Enable DHCP logging
log-dhcp

# DHCP IP range (configured via UI)
# dhcp-range=192.168.0.10,192.168.0.254,12h

# Static DNS for CBT server (configured via UI)
# address=/cbtsrv.snpmb.id/YOUR_CBS_SERVER_IP

# Bind to specific interface only (auto-set by UI)
# listen-address=YOUR_SERVER_IP
# bind-interfaces
